logs/

# Terraform (infra/terraform) — state and secrets stay local; the lock file IS committed
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/terraform.tfvars
infra/terraform/crash.log

# Ansible — real inventory contains the VM IP; the example is committed
infra/ansible/inventory.ini
